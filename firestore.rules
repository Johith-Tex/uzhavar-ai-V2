// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own chat messages
    match /chats/{userId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Anyone authenticated can write feedback and sessions
    match /feedback/{docId} {
      allow write: if request.auth != null;
      allow read: if false; // Admin only
    }

    match /sessions/{docId} {
      allow write: if request.auth != null;
      allow read: if false;
    }

    // Weather cache — readable by all, writable by authenticated
    match /weather_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
